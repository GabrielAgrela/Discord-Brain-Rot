{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-notificator"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp",
        "--output-dir",
        "/tmp/opencode-playwright-mcp/Discord-Brain-Rot",
        "--output-mode",
        "file",
        "--image-responses",
        "omit"
      ],
      "enabled": true
    }
  }
}
