{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sqlite": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-sqlite",
        "--db",
        "/home/gabi/github/Discord-Brain-Rot/Data/database.db"
      ],
      "enabled": true
    },
    "docker": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "docker-mcp"
      ],
      "environment": {
        "DOCKER_MCP_LOCAL": "true"
      },
      "enabled": true
    }
  }
}
